*.js
*.d.ts
!jest.config.js
node_modules
dist
cdk.out
.cdk.staging
*.env
.env.*
*.pem
*.key
.DS_Store
Thumbs.db

# Testing-harness shape-chip corpus is staged at build time from a
# private forgenew checkout (see scripts/harness-build.sh). Never commit
# the staged contents. The empty directory + .gitkeep are tracked so
# `COPY corpus/ /corpus/` in the Dockerfile always has a valid source.
docker/testing-harness/corpus/*
!docker/testing-harness/corpus/.gitkeep
