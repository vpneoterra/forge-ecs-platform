; Forgejo configuration (rendered by forge-entrypoint.sh).
; Data root is the EFS mount /forge/repos so repos + SQLite db are durable.
APP_NAME = FORGE Git
RUN_USER = git
RUN_MODE = prod
WORK_PATH = /forge/repos

[server]
DOMAIN           = ${FORGEJO_DOMAIN}
HTTP_ADDR        = 127.0.0.1
HTTP_PORT        = ${FORGEJO_HTTP_PORT}
ROOT_URL         = ${FORGEJO_ROOT_URL}
DISABLE_SSH      = false
SSH_DOMAIN       = ${FORGEJO_DOMAIN}
LFS_START_SERVER = true
OFFLINE_MODE     = true

[database]
DB_TYPE = sqlite3
PATH    = /forge/repos/forgejo.db

[repository]
ROOT = /forge/repos/repositories

[lfs]
PATH = /forge/repos/lfs

[security]
INSTALL_LOCK = true
; SECRET_KEY / INTERNAL_TOKEN are auto-generated by Forgejo on first run and
; persisted into the SQLite db on EFS.

[service]
DISABLE_REGISTRATION              = true
REQUIRE_SIGNIN_VIEW               = true
REGISTER_EMAIL_CONFIRM            = false
ENABLE_NOTIFY_MAIL                = false
DEFAULT_KEEP_EMAIL_PRIVATE        = true
DEFAULT_ALLOW_CREATE_ORGANIZATION = true

[openid]
ENABLE_OPENID_SIGNIN = false

[log]
MODE  = console
LEVEL = info
