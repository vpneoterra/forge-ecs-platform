# llmcluster-gemma: llama.cpp server for Gemma 4 26B-A4B-it GGUF
# Internal alias: gemma-4-26b-a4b-it-gguf-osc
# Model: unsloth/gemma-4-26B-A4B-it-GGUF, file UD-Q4_K_M (~16.9GB)
# GPU: A10G 24GB (g5.2xlarge)
FROM 266087050444.dkr.ecr.us-east-1.amazonaws.com/llmcluster-llamacpp:latest

# Model loaded from EFS at /models/gemma-osc/ or downloaded via HF_TOKEN
ENV MODEL_ALIAS=gemma-osc
ENV MODEL_REPO=unsloth/gemma-4-26B-A4B-it-GGUF
ENV MODEL_FILE=gemma-4-26B-A4B-it-UD-Q4_K_M.gguf

EXPOSE 8000

CMD ["sh", "-c", "\
  MODEL_PATH=/models/${MODEL_ALIAS}/${MODEL_FILE}; \
  if [ ! -f \"$MODEL_PATH\" ]; then \
    echo 'Model not on EFS, downloading...'; \
    mkdir -p /models/${MODEL_ALIAS}; \
    python3 -c \"from huggingface_hub import hf_hub_download; hf_hub_download(repo_id='${MODEL_REPO}', filename='${MODEL_FILE}', local_dir='/models/${MODEL_ALIAS}', token='${HF_TOKEN}')\"; \
  fi; \
  exec llama-server \
    --model $MODEL_PATH \
    --host 0.0.0.0 \
    --port 8000 \
    --ctx-size 8192 \
    --n-gpu-layers 999 \
    --alias unsloth/gemma-4-26B-A4B-it-GGUF \
    --chat-template gemma"]
